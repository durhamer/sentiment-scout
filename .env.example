# Reddit: 不需要 API key！使用公開 JSON endpoints
# (未來如果取得官方 API credentials，可以在這裡加上)

# Anthropic API (for reply drafting)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Threads API（Meta Graph API）
# 長期 token（有效期 60 天），需定期更換
THREADS_ACCESS_TOKEN=your_threads_long_lived_access_token
# 你的 Threads 帳號 User ID（數字字串）
THREADS_USER_ID=your_threads_user_id
